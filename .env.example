# ─────────────────────────────────────────────────────────────
# API Claude (Anthropic) — utilisée UNIQUEMENT côté serveur.
# Ne jamais préfixer cette clé par NEXT_PUBLIC_.
# https://console.anthropic.com/
# ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Supabase — Project Settings > API
# https://supabase.com/dashboard/project/_/settings/api
# ─────────────────────────────────────────────────────────────
# URL et clé "anon" : exposées au client (préfixe NEXT_PUBLIC_ obligatoire).
# La sécurité repose sur le RLS, pas sur le secret de la clé anon.
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL publique du site (pour les redirections du magic link).
# En local : http://localhost:3000 — sur Vercel : https://votre-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000
